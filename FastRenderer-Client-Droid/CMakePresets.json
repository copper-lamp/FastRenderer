{
    "version": 3,
    "configurePresets": [
        {
            "name": "android-release",
            "displayName": "Android Release (arm64-v8a)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/android-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_MAKE_PROGRAM": "${sourceDir}/tools/ninja/ninja.exe",
                "CMAKE_TOOLCHAIN_FILE": "$env{ANDROID_NDK_HOME}/build/cmake/android.toolchain.cmake",
                "ANDROID_ABI": "arm64-v8a",
                "ANDROID_PLATFORM": "28",
                "ANDROID_STL": "c++_shared",
                "CMAKE_CXX_STANDARD": "20",
                "CMAKE_CXX_STANDARD_REQUIRED": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "android-release",
            "configurePreset": "android-release"
        }
    ]
}